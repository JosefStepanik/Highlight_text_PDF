using System;
using System.Collections.Generic;
using System.Drawing;
using System.IO;
using System.Linq;
using System.Text;
using System.Windows.Forms;
using iText.Kernel.Pdf;
using iText.Kernel.Pdf.Canvas.Parser;
using iText.Kernel.Pdf.Canvas.Parser.Listener;

namespace PdfHighlighter
{
    public partial class MainForm : Form
    {
        private Button btnSelectPdf = null!;
        private TextBox txtSearchTerms = null!;
        private Button btnHighlight = null!;
        private TextBox txtPdfContent = null!;
        private Label lblStatus = null!;
        private Button btnPrevPage = null!;
        private Button btnNextPage = null!;
        private Label lblPageInfo = null!;
        private ListBox lstSearchResults = null!;

        // PDF related fields
        private PdfDocument? pdfDocument;
        private int currentPageIndex = 0;
        private List<string> searchTerms = new List<string>();
        private string? currentPdfPath;
        private Dictionary<int, string> pageContents = new Dictionary<int, string>();

        public MainForm()
        {
            InitializeComponent();
        }

        private void InitializeComponent()
        {
            this.SuspendLayout();

            // Form properties
            this.Text = "PDF Text Highlighter";
            this.Size = new Size(1000, 700);
            this.StartPosition = FormStartPosition.CenterScreen;
            this.MinimumSize = new Size(800, 600);

            // Main layout
            var mainPanel = new TableLayoutPanel
            {
                Dock = DockStyle.Fill,
                ColumnCount = 2,
                RowCount = 3
            };
            mainPanel.RowStyles.Add(new RowStyle(SizeType.Absolute, 80));  // Toolbar
            mainPanel.RowStyles.Add(new RowStyle(SizeType.Percent, 70));   // Content
            mainPanel.RowStyles.Add(new RowStyle(SizeType.Percent, 30));   // Search results
            mainPanel.ColumnStyles.Add(new ColumnStyle(SizeType.Percent, 100));

            // Toolbar
            var toolbar = CreateToolbar();
            mainPanel.Controls.Add(toolbar, 0, 0);
            mainPanel.SetColumnSpan(toolbar, 2);

            // PDF content viewer
            var contentPanel = CreateContentViewer();
            mainPanel.Controls.Add(contentPanel, 0, 1);

            // Search results panel
            var searchPanel = CreateSearchResultsPanel();
            mainPanel.Controls.Add(searchPanel, 0, 2);

            this.Controls.Add(mainPanel);
            this.ResumeLayout(false);
        }

        private Panel CreateToolbar()
        {
            var toolbar = new Panel
            {
                Dock = DockStyle.Fill,
                BackColor = SystemColors.Control,
                Padding = new Padding(10)
            };

            var layout = new TableLayoutPanel
            {
                Dock = DockStyle.Fill,
                ColumnCount = 6,
                RowCount = 2
            };

            // First row - File selection and navigation
            var lblFile = new Label
            {
                Text = "PDF soubor:",
                AutoSize = true,
                Anchor = AnchorStyles.Left | AnchorStyles.Top,
                Margin = new Padding(0, 5, 10, 5)
            };
            layout.Controls.Add(lblFile, 0, 0);

            btnSelectPdf = new Button
            {
                Text = "Vybrat PDF soubor...",
                AutoSize = true,
                Margin = new Padding(0, 0, 10, 5)
            };
            btnSelectPdf.Click += BtnSelectPdf_Click;
            layout.Controls.Add(btnSelectPdf, 1, 0);

            btnPrevPage = new Button
            {
                Text = "◀ Předchozí",
                AutoSize = true,
                Enabled = false,
                Margin = new Padding(0, 0, 5, 5)
            };
            btnPrevPage.Click += BtnPrevPage_Click;
            layout.Controls.Add(btnPrevPage, 2, 0);

            btnNextPage = new Button
            {
                Text = "Následující ▶",
                AutoSize = true,
                Enabled = false,
                Margin = new Padding(0, 0, 10, 5)
            };
            btnNextPage.Click += BtnNextPage_Click;
            layout.Controls.Add(btnNextPage, 3, 0);

            lblPageInfo = new Label
            {
                Text = "Žádný PDF",
                AutoSize = true,
                Anchor = AnchorStyles.Left | AnchorStyles.Top,
                Margin = new Padding(0, 5, 10, 5)
            };
            layout.Controls.Add(lblPageInfo, 4, 0);

            // Second row - Search
            var lblSearch = new Label
            {
                Text = "Hledané výrazy (oddělené čárkou):",
                AutoSize = true,
                Anchor = AnchorStyles.Left | AnchorStyles.Top,
                Margin = new Padding(0, 5, 10, 0)
            };
            layout.Controls.Add(lblSearch, 0, 1);

            txtSearchTerms = new TextBox
            {
                PlaceholderText = "například: slovo1, dlouhá fráze, jiný text",
                Width = 300,
                Margin = new Padding(0, 0, 10, 0)
            };
            txtSearchTerms.KeyDown += TxtSearchTerms_KeyDown;
            layout.Controls.Add(txtSearchTerms, 1, 1);
            layout.SetColumnSpan(txtSearchTerms, 2);

            btnHighlight = new Button
            {
                Text = "🔍 Vyhledat text",
                AutoSize = true,
                Enabled = false,
                Margin = new Padding(0, 0, 10, 0)
            };
            btnHighlight.Click += BtnHighlight_Click;
            layout.Controls.Add(btnHighlight, 3, 1);

            // Status label
            lblStatus = new Label
            {
                Text = "Připraven. Vyberte PDF soubor pro začátek.",
                AutoSize = true,
                Anchor = AnchorStyles.Left | AnchorStyles.Top,
                Margin = new Padding(0, 5, 0, 0)
            };
            layout.Controls.Add(lblStatus, 4, 1);
            layout.SetColumnSpan(lblStatus, 2);

            toolbar.Controls.Add(layout);
            return toolbar;
        }

        private Control CreateContentViewer()
        {
            var contentPanel = new GroupBox
            {
                Text = "Obsah PDF stránky",
                Dock = DockStyle.Fill,
                Padding = new Padding(10)
            };

            txtPdfContent = new TextBox
            {
                Multiline = true,
                ScrollBars = ScrollBars.Both,
                ReadOnly = true,
                Dock = DockStyle.Fill,
                Font = new Font("Consolas", 10),
                BackColor = Color.White,
                Text = "Vyberte PDF soubor pro zobrazení obsahu..."
            };

            contentPanel.Controls.Add(txtPdfContent);
            return contentPanel;
        }

        private Control CreateSearchResultsPanel()
        {
            var searchPanel = new GroupBox
            {
                Text = "Výsledky vyhledávání",
                Dock = DockStyle.Fill,
                Padding = new Padding(10)
            };

            lstSearchResults = new ListBox
            {
                Dock = DockStyle.Fill,
                Font = new Font("Consolas", 9)
            };
            lstSearchResults.DoubleClick += LstSearchResults_DoubleClick;

            searchPanel.Controls.Add(lstSearchResults);
            return searchPanel;
        }

        private void BtnSelectPdf_Click(object sender, EventArgs e)
        {
            using var openFileDialog = new OpenFileDialog
            {
                Filter = "PDF soubory (*.pdf)|*.pdf|Všechny soubory (*.*)|*.*",
                FilterIndex = 1,
                RestoreDirectory = true,
                Title = "Vyberte PDF soubor"
            };

            if (openFileDialog.ShowDialog() == DialogResult.OK)
            {
                LoadPdfFile(openFileDialog.FileName);
            }
        }

        private void LoadPdfFile(string filePath)
        {
            try
            {
                // Close previous document
                pdfDocument?.Close();
                pageContents.Clear();

                // Load new document using iText
                pdfDocument = new PdfDocument(new PdfReader(filePath));
                currentPdfPath = filePath;
                currentPageIndex = 0;

                if (pdfDocument.GetNumberOfPages() > 0)
                {
                    btnHighlight.Enabled = true;
                    btnPrevPage.Enabled = false;
                    btnNextPage.Enabled = pdfDocument.GetNumberOfPages() > 1;

                    // Extract text from all pages
                    ExtractAllPageTexts();

                    UpdatePageInfo();
                    DisplayCurrentPage();

                    lblStatus.Text = $"Načten PDF: {Path.GetFileName(filePath)} ({pdfDocument.GetNumberOfPages()} stránek)";
                }
                else
                {
                    MessageBox.Show("PDF soubor neobsahuje žádné stránky.", "Chyba", 
                                  MessageBoxButtons.OK, MessageBoxIcon.Warning);
                }
            }
            catch (Exception ex)
            {
                MessageBox.Show($"Chyba při načítání PDF souboru:\n{ex.Message}", 
                              "Chyba", MessageBoxButtons.OK, MessageBoxIcon.Error);
                lblStatus.Text = "Chyba při načítání PDF souboru.";
            }
        }

        private void ExtractAllPageTexts()
        {
            if (pdfDocument == null) return;

            pageContents.Clear();
            
            for (int i = 1; i <= pdfDocument.GetNumberOfPages(); i++)
            {
                try
                {
                    var page = pdfDocument.GetPage(i);
                    var strategy = new SimpleTextExtractionStrategy();
                    var text = PdfTextExtractor.GetTextFromPage(page, strategy);
                    pageContents[i - 1] = text;
                }
                catch (Exception ex)
                {
                    pageContents[i - 1] = $"Chyba při extrakci textu ze stránky {i}: {ex.Message}";
                }
            }
        }

        private void DisplayCurrentPage()
        {
            if (pageContents.ContainsKey(currentPageIndex))
            {
                txtPdfContent.Text = pageContents[currentPageIndex];
            }
            else
            {
                txtPdfContent.Text = "Nepodařilo se načíst obsah této stránky.";
            }
        }

        private void BtnHighlight_Click(object sender, EventArgs e)
        {
            ParseSearchTerms();
            SearchInAllPages();
        }

        private void ParseSearchTerms()
        {
            searchTerms.Clear();
            
            if (string.IsNullOrWhiteSpace(txtSearchTerms.Text))
                return;

            var terms = txtSearchTerms.Text.Split(',', StringSplitOptions.RemoveEmptyEntries);
            foreach (var term in terms)
            {
                var trimmed = term.Trim();
                if (!string.IsNullOrEmpty(trimmed))
                {
                    searchTerms.Add(trimmed);
                }
            }
        }

        private void SearchInAllPages()
        {
            lstSearchResults.Items.Clear();
            
            if (searchTerms.Count == 0 || pageContents.Count == 0)
            {
                lblStatus.Text = "Zadejte hledané výrazy.";
                return;
            }

            int totalMatches = 0;

            foreach (var kvp in pageContents)
            {
                int pageIndex = kvp.Key;
                string pageText = kvp.Value;
                
                foreach (var term in searchTerms)
                {
                    int index = 0;
                    while ((index = pageText.IndexOf(term, index, StringComparison.OrdinalIgnoreCase)) != -1)
                    {
                        // Extract context around the match
                        int start = Math.Max(0, index - 30);
                        int end = Math.Min(pageText.Length, index + term.Length + 30);
                        string context = pageText.Substring(start, end - start).Replace('\n', ' ').Replace('\r', ' ');
                        
                        // Highlight the search term in context
                        int termStart = index - start;
                        string highlightedContext = context.Insert(termStart + term.Length, "]")
                                                          .Insert(termStart, "[");
                        
                        lstSearchResults.Items.Add($"Stránka {pageIndex + 1}: ...{highlightedContext}...");
                        totalMatches++;
                        index += term.Length;
                    }
                }
            }

            if (totalMatches > 0)
            {
                lblStatus.Text = $"Nalezeno {totalMatches} výskytů hledaných výrazů.";
                
                // Highlight text in current page view
                HighlightTextInCurrentPage();
            }
            else
            {
                lblStatus.Text = "Žádné výskyty hledaných výrazů nebyly nalezeny.";
            }
        }

        private void HighlightTextInCurrentPage()
        {
            if (!pageContents.ContainsKey(currentPageIndex) || searchTerms.Count == 0)
                return;

            string text = pageContents[currentPageIndex];
            string highlightedText = text;

            // Simple text highlighting by wrapping terms in brackets
            foreach (var term in searchTerms)
            {
                highlightedText = System.Text.RegularExpressions.Regex.Replace(
                    highlightedText, 
                    System.Text.RegularExpressions.Regex.Escape(term), 
                    $">>> {term} <<<", 
                    System.Text.RegularExpressions.RegexOptions.IgnoreCase
                );
            }

            txtPdfContent.Text = highlightedText;
        }

        private void BtnPrevPage_Click(object sender, EventArgs e)
        {
            if (currentPageIndex > 0)
            {
                currentPageIndex--;
                UpdatePageInfo();
                DisplayCurrentPage();
                UpdateNavigationButtons();
                
                // Re-highlight if search terms exist
                if (searchTerms.Count > 0)
                {
                    HighlightTextInCurrentPage();
                }
            }
        }

        private void BtnNextPage_Click(object sender, EventArgs e)
        {
            if (pdfDocument != null && currentPageIndex < pdfDocument.GetNumberOfPages() - 1)
            {
                currentPageIndex++;
                UpdatePageInfo();
                DisplayCurrentPage();
                UpdateNavigationButtons();
                
                // Re-highlight if search terms exist
                if (searchTerms.Count > 0)
                {
                    HighlightTextInCurrentPage();
                }
            }
        }

        private void UpdateNavigationButtons()
        {
            if (pdfDocument == null)
            {
                btnPrevPage.Enabled = false;
                btnNextPage.Enabled = false;
                return;
            }

            btnPrevPage.Enabled = currentPageIndex > 0;
            btnNextPage.Enabled = currentPageIndex < pdfDocument.GetNumberOfPages() - 1;
        }

        private void UpdatePageInfo()
        {
            if (pdfDocument == null)
            {
                lblPageInfo.Text = "Žádný PDF";
            }
            else
            {
                lblPageInfo.Text = $"Stránka {currentPageIndex + 1} z {pdfDocument.GetNumberOfPages()}";
            }
        }

        private void TxtSearchTerms_KeyDown(object sender, KeyEventArgs e)
        {
            if (e.KeyCode == Keys.Enter && btnHighlight.Enabled)
            {
                BtnHighlight_Click(sender, e);
                e.SuppressKeyPress = true;
            }
        }

        private void LstSearchResults_DoubleClick(object sender, EventArgs e)
        {
            if (lstSearchResults.SelectedItem != null)
            {
                string selectedItem = lstSearchResults.SelectedItem.ToString()!;
                
                // Extract page number from the selected result
                var match = System.Text.RegularExpressions.Regex.Match(selectedItem, @"Stránka (\d+):");
                if (match.Success && int.TryParse(match.Groups[1].Value, out int pageNumber))
                {
                    currentPageIndex = pageNumber - 1;
                    UpdatePageInfo();
                    DisplayCurrentPage();
                    UpdateNavigationButtons();
                    HighlightTextInCurrentPage();
                }
            }
        }

        protected override void OnFormClosing(FormClosingEventArgs e)
        {
            // Clean up resources
            pdfDocument?.Close();
            base.OnFormClosing(e);
        }

        protected override bool ProcessCmdKey(ref Message msg, Keys keyData)
        {
            // Handle keyboard shortcuts
            switch (keyData)
            {
                case Keys.Left:
                case Keys.PageUp:
                    if (btnPrevPage.Enabled)
                    {
                        BtnPrevPage_Click(this, EventArgs.Empty);
                        return true;
                    }
                    break;

                case Keys.Right:
                case Keys.PageDown:
                    if (btnNextPage.Enabled)
                    {
                        BtnNextPage_Click(this, EventArgs.Empty);
                        return true;
                    }
                    break;

                case Keys.F | Keys.Control:
                    txtSearchTerms.Focus();
                    return true;
            }

            return base.ProcessCmdKey(ref msg, keyData);
        }
    }
}